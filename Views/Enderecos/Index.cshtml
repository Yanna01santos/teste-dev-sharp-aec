@model List<AEC.Models.Endereco>

@{
    ViewData["Title"] = "Endereços";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>Meus Endereços</h2>
            <p class="text-muted mb-0">Bem-vindo(a), @ViewBag.UsuarioNome</p>
        </div>

        <div>
            <a asp-action="Criar" class="btn btn-primary">Novo Endereço</a>
            <a asp-controller="Login" asp-action="Sair" class="btn btn-outline-danger">Sair</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Nenhum endereço cadastrado.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>CEP</th>
                    <th>Logradouro</th>
                    <th>Número</th>
                    <th>Bairro</th>
                    <th>Cidade</th>
                    <th>UF</th>
                    <th style="width: 180px;">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var endereco in Model)
                {
                    <tr>
                        <td>@endereco.Cep</td>
                        <td>@endereco.Logradouro</td>
                        <td>@endereco.Numero</td>
                        <td>@endereco.Bairro</td>
                        <td>@endereco.Cidade</td>
                        <td>@endereco.Uf</td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@endereco.Id" class="btn btn-sm btn-warning">
                                Editar
                            </a>

                            <a asp-action="Excluir" asp-route-id="@endereco.Id" class="btn btn-sm btn-danger">
                                Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>