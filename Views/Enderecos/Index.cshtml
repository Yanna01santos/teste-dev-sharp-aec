@{
    ViewData["Title"] = "Endereços";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Meus Endereços</h2>

        <a asp-controller="Login" asp-action="Sair" class="btn btn-outline-danger">
            Sair
        </a>
    </div>

    <div class="alert alert-success">
        Login realizado com sucesso. Bem-vindo(a), @ViewBag.UsuarioNome!
    </div>

    <p>
        Esta será a página do CRUD de endereços.
    </p>
</div>