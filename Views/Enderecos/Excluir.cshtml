@model AEC.Models.Endereco

@{
    ViewData["Title"] = "Excluir Endereço";
}

<div class="container mt-4">
    <h2>Excluir Endereço</h2>

    <div class="alert alert-warning">
        Tem certeza que deseja excluir este endereço?
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>CEP:</strong> @Model.Cep</p>
            <p><strong>Logradouro:</strong> @Model.Logradouro</p>
            <p><strong>Número:</strong> @Model.Numero</p>
            <p><strong>Bairro:</strong> @Model.Bairro</p>
            <p><strong>Cidade:</strong> @Model.Cidade</p>
            <p><strong>UF:</strong> @Model.Uf</p>
        </div>
    </div>

    <form asp-action="ConfirmarExclusao" method="post" class="mt-3">
        <input type="hidden" name="id" value="@Model.Id" />

        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>